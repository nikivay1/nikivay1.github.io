---
import '../styles/global.css';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale, LocaleLink, PortfolioContent } from '../i18n';
import { shared } from '../i18n/shared';
import { withBase } from '../utils/url';

interface Props {
  lang: Locale;
  meta: PortfolioContent['meta'];
  alternateLinks: readonly LocaleLink[];
}

const { lang, meta, alternateLinks } = Astro.props;
const faviconUrl = withBase('favicon.svg');
const siteUrl = Astro.site ?? new URL('https://nikivay1.github.io');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const rootUrl = new URL('/', siteUrl);
const ogImageUrl = new URL(meta.ogImage, siteUrl);
const absoluteAlternateLinks = alternateLinks.map((link) => ({
  ...link,
  href: new URL(link.href, siteUrl).href,
}));
const ogLocales: Record<Locale, string> = {
  en: 'en_US',
  ru: 'ru_RU',
  es: 'es_ES',
};
const personJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL('/#person', siteUrl).href,
  name: shared.profile.name,
  givenName: shared.profile.givenName,
  familyName: shared.profile.familyName,
  jobTitle: shared.profile.jobTitle,
  url: rootUrl.href,
  sameAs: shared.profile.sameAs,
}).replaceAll('<', '\\u003c');
---

<!doctype html>
<html lang={lang} prefix="og: https://ogp.me/ns# profile: https://ogp.me/ns/profile#">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={meta.description} />
    <meta name="theme-color" content="#f1efe9" />
    <link rel="canonical" href={canonicalUrl.href} />
    {absoluteAlternateLinks.map((link) => <link rel="alternate" hreflang={link.code} href={link.href} />)}
    <link rel="alternate" hreflang="x-default" href={new URL(getRelativeLocaleUrl('en'), siteUrl).href} />

    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.ogDescription} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content={shared.profile.name} />
    <meta property="og:locale" content={ogLocales[lang]} />
    {Object.entries(ogLocales).filter(([locale]) => locale !== lang).map(([, locale]) => <meta property="og:locale:alternate" content={locale} />)}
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:secure_url" content={ogImageUrl.href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={meta.ogImageAlt} />
    <meta property="profile:first_name" content={shared.profile.givenName} />
    <meta property="profile:last_name" content={shared.profile.familyName} />
    <meta property="profile:username" content={shared.profile.username} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.ogDescription} />
    <meta name="twitter:image" content={ogImageUrl.href} />
    <meta name="twitter:image:alt" content={meta.ogImageAlt} />

    <script type="application/ld+json" set:html={personJsonLd}></script>
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <title>{meta.title}</title>
  </head>
  <body class="m-0 overflow-x-hidden bg-paper text-ink antialiased selection:bg-signal selection:text-paper">
    <a class="fixed -top-20 left-4 z-50 bg-ink px-4 py-3 text-sm font-bold text-white focus:top-4" href="#main">
      {meta.skipToContent}
    </a>
    <slot />
  </body>
</html>
