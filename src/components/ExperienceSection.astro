---
import ExperienceCard from './ExperienceCard.astro';
import type { ExperienceContent } from '../i18n';
import SectionHeader from './SectionHeader.astro';

interface Props {
  content: ExperienceContent;
}

const { content } = Astro.props;
---

<section class="section-shell" id="work" aria-labelledby="work-title">
  <SectionHeader index={content.index} title={content.title} id="work-title" />

  <div class="border-t border-ink">
    {content.jobs.map((job) => <ExperienceCard job={job} technologiesLabel={content.technologiesLabel} />)}
  </div>
</section>
